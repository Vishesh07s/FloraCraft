# Database & Port Configuration
MONGO_URI=mongodb://localhost:27017/floracraft_plants
PORT=4000

# Environment Mode
NODE_ENV=development # Set to 'production' in production environment

# Admin Credentials
# In production, default/fallback credentials will be rejected.
ADMIN_USERNAME=admin
# Secure Bcrypt hash of admin password.
# To generate a hash: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
ADMIN_PASSWORD_HASH=$2a$10$lQeHjQjSgL0dI/YjC/7J1O.b/4U5Lw2vD0F6471V0lQv1wS4gT2.C # e.g. for default 'admin123'
# Plain password is only supported in local development fallback
ADMIN_PASSWORD=admin123

# JWT Configuration
# In production, this must be a secure 256-bit key.
# Generate with: openssl rand -hex 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=floracraft_jwt_secret_token_key_development_only_123

# CORS Configuration
# Origin of the frontend application. In production, this must be explicitly set and not wildcard/mirrored.
FRONTEND_URL=http://localhost:5173

# Google OAuth 2.0 Configuration
# Set up a Google Cloud Project to obtain a Client ID.
GOOGLE_CLIENT_ID=